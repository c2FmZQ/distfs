{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "outDir": "./web/js",
    "rootDir": "./web/ts",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node"
  },
  "include": [
    "web/ts/**/*"
  ]
}